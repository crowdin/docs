---
import Default from '@astrojs/starlight/components/Footer.astro';
import Feedback from '~/components/Feedback.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { isStarlightHomepage } from '~/utils/starlightRoute';

const isHomepage = isStarlightHomepage(Astro.locals.starlightRoute);
const locale = Astro.locals.starlightRoute.lang;
const year = new Date().getFullYear();

const showFeedback = !isHomepage &&
    !['404', 'iframe/privacy-policy', 'iframe/terms'].includes(Astro.locals.starlightRoute.id);
---

<style>
    footer a {
        color: var(--crowdin-text-muted);

        &:hover {
            color: var(--crowdin-body-color);
        }
    }
</style>

{isHomepage ? (
    <hr class="h-px mt-12 mb-8 bg-gray-200 border-0 dark:bg-gray-700">
    <footer class="sl-flex">
        <div class="flex flex-col gap-6 text-sm sm:flex-row sm:items-center">
            <p class="sm:mr-auto">Crowdin &copy; {year}</p>
            <div class="grid grid-cols-2 gap-4 sm:flex sm:gap-6">
                <a class="no-underline" href="https://status.crowdin.com/" target="_blank">{Astro.locals.t('footer.status')}</a>
                <a class="no-underline" href={getRelativeLocaleUrl(locale, 'terms')}>{Astro.locals.t('footer.terms')}</a>
                <a class="no-underline" href={getRelativeLocaleUrl(locale, 'privacy-policy')}>{Astro.locals.t('footer.privacy')}</a>
                <a class="no-underline" href={getRelativeLocaleUrl(locale, 'cookies')}>{Astro.locals.t('footer.cookies')}</a>
                <a class="no-underline" href="https://crowdin.com/page/security">{Astro.locals.t('footer.security')}</a>
                <a class="no-underline" href="/llms.txt">{Astro.locals.t('footer.llms')}</a>
            </div>
        </div>
    </footer>
    ) : (
        <Default><slot /></Default>
    )
}

{showFeedback && (
    <div class="w-full flex">
        <div class="mx-auto">
            <Feedback />
        </div>
    </div>
)}
