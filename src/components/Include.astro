---
import { basename } from 'node:path';

interface Props {
  /** Base name only (e.g. `word-counter.mdx`). Crowdin writes translations to `includes/<locale>/`. */
  file: string;
}

const { file: fileProp } = Astro.props;
const file = basename(fileProp);
if (file !== fileProp || file.includes('..')) {
  throw new Error(
    `Include \`file\` must be a single MDX file name in src/content/includes/ (no paths). Got: ${JSON.stringify(fileProp)}`
  );
}

const currentLocale = Astro.currentLocale ?? 'root';

// Look up all the Markdown files in the includes folder.
const includes = import.meta.glob('../content/includes/**/*.mdx');

// Resolve locale-specific include first (Crowdin: includes/%two_letters_code%/<name>), then English default.
const candidatePaths = currentLocale === 'root'
  ? [`../content/includes/${file}`]
  : [
      `../content/includes/${currentLocale}/${file}`,
      `../content/includes/${file}`,
    ];

const loaderPath = candidatePaths.find((path) => path in includes);
const loader = loaderPath ? includes[loaderPath] : undefined;

if (!loader) {
  throw new Error(
    `Could not find include \`${file}\` for locale \`${currentLocale}\`. Checked: ${candidatePaths.join(', ')}.`
  );
}

const { Content } = await loader() as any;
---

<Content />
